;--------;
; COLORS ;
;--------;
[colors]
background = #00000000
foreground = #FFFFFF
alert = #bd2c40
pink = #E0AFCF
skyBlue = #AFCFE0
midBlue = #27495F
grey = #666666

;------;
; BARS ;
;------;

[bars/shared]
width = 100%
height = 25
override-redirect = true
wm-restack = bspwm
fixed-center = true
enable-ipc = true
background = ${colors.background}
foreground = ${colors.foreground}
padding = 2
line-size = 2
font-0 = "FiraSans:style=bold:size=10;0"
font-1 = "Symbols Nerd Font:style=2048-em;1"
cursor-click = pointer
cursor-scroll = ns-resize



[bar/polyleft]
monitor = ${env:MONITOR:DisplayPort-2}
inherit = bars/shared
modules-left = previous playpause next spotify
modules-right = bspwm 



[bar/polyright]
monitor = ${env:MONITOR:HDMI-A-0}
inherit = bars/shared
tray-position = right
modules-left = bspwm
modules-right = upd-arch cpu memory lan2 alsa date2 powermenu



;---------;
; MODULES ;
;---------;

