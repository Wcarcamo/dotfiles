;--------;
; COLORS ;
;--------;
[colors]
background = #00000000
foreground = #dfdfdf
alert = #bd2c40
;volcano_pink = #FFc0cb
city_pink = #E0AFCF
skyBlue = #AFCFE0
midBlue = #27495F


;------;
; BARS ;
;------;

[bars/shared]
width = 100%
height = 25
override-redirect = true
wm-restack = bspwm
fixed-center = true
enable-ipc = true
background = ${colors.background}
foreground = ${colors.foreground}
padding = 2
line-size = 2
font-0 = "FiraSans:style=bold:size=10;0"
font-1 = "Symbols Nerd Font:style=2048-em;1"
cursor-click = pointer
cursor-scroll = ns-resize



[bar/polyleft]
monitor = ${env:MONITOR:HDMI-A-0}
inherit = bars/shared
modules-left = spotify
modules-center = previous playpause next 
modules-right = bspwm



[bar/polyright]
monitor = ${env:MONITOR:DVI-D-0}
inherit = bars/shared
tray-position = right
modules-left = bspwm
modules-right = upd-arch cpu memory lan alsa date powermenu



;---------;
; MODULES ;
;---------;

[module/bspwm]
type = internal/bspwm
; ’│Æ Ņ£ī ’¬┐
ws-icon-0 = 1;’ē®
ws-icon-1 = 2;Ņ£ī
ws-icon-2 = 3;’│Æ
ws-icon-3 = 4;’¬┐
ws-icon-4 = 5;’īā
ws-icon-5 = 6;’å╝
ws-icon-6 = 7;’äĀ
ws-icon-7 = 8;’āĀ
ws-icon-8 = 9;’Ł«
ws-icon-9 = 10;’īā
ws-icon-default = ’īā
label-focused = %icon%
label-focused-foreground = ${colors.city_pink}
label-focused-padding = 2
label-occupied = %icon%
label-occupied-foreground = ${colors.skyBlue}
label-occupied-padding = 2
label-empty = %icon%
label-empty-foreground = ${colors.midBlue}
label-empty-padding = 2



[module/date]
type = internal/date
interval = 5
;date = %m/%e
date = %e
time = %I:%M
format-prefix =
format-prefix-foreground = ${colors.foreground}
format-padding = 3
;’ü│ %date%   
label = "ŅÄģ %time%"



[module/alsa]
type = internal/alsa
format-volume = <ramp-volume> <label-volume>
format-volume-padding = 3
format-muted-padding = 3
label-volume = %percentage%
label-muted = ’¬Ć
label-muted-foreground = ${colors.city_pink}
ramp-volume-0 = ’®Š
ramp-volume-1 = ’®┐
ramp-volume-2 = ’®Į



[module/powermenu]
type = custom/menu
expand-right = true
format-spacing = 1
format-padding = 1
label-open = ’Ćæ
label-open-foreground = ${colors.city_pink}
label-close = ’æ¦
label-close-foreground = ${colors.city_pink}
label-separator = |
label-separator-foreground = ${colors.foreground}
menu-0-0 = ’ĆĪ
menu-0-0-exec = reboot
menu-0-1 = ’Ćæ
menu-0-1-exec = poweroff



[module/upd-arch]
type = custom/script
exec = ~/.config/polybar/poly-scripts/updates-arch.sh
interval = 600
format-padding = 3



[module/lan]
type = internal/network
interface = enp24s0
interval = 3.0
format-connected = <label-connected>
format-connected-padding = 3
format-disconnected = <label-disconnected>
label-connected = ’é¼
label-connected-foreground = ${colors.foreground}
