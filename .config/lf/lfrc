# Basic Settings
set preview true
set hidden true
set icons true
set relativenumber true

# Bindings
# Remove some defaults
map m
map o
map n
map "'"
map '"'
map d
map c
map e
map f

# File Openers
map e $$EDITOR "$f"
map u $view "$f"


# Basic Functions
map . set hidden!
map DD delete
map p paste
map x cut
map y copy
map r rename
map H top
map L bottom
map R reload
map C clear
map U unselect

# Movement
map gtr cd ~/.local/share/Trash/files

map gw. cd ~/.config/wallpapers

map gD cd ~/Documents

map gd cd ~/Downloads

map gc cd ~/.config
map gE cd /etc
map gU. cd /usr
map gUs cd /usr/share
